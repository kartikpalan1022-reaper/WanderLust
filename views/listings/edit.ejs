<% layout("/layouts/boilerplate") %>

<body>
  <div class="row">
    <div class="col-md-8 offset-md-2">
      <h1>Edit Listing</h1>

      <form 
        action="/listings/<%= listing._id %>?_method=PUT" 
        method="POST" 
        enctype="multipart/form-data" 
        novalidate 
        class="needs-validation"
      >

        <!-- TITLE -->
        <div class="mb-3">
          <label class="form-label">Title:</label>
          <input class="form-control" type="text" name="listing[title]" value="<%= listing.title %>" required>
        </div>

        <!-- DESCRIPTION -->
        <div class="mb-3">
          <label class="form-label">Description:</label>
          <textarea class="form-control" name="listing[description]" required><%= listing.description %></textarea>
        </div>

        <!-- PRICE + LOCATION -->
        <div class="row">
          <div class="mb-3 col-md-4">
            <label class="form-label">Price:</label>
            <input class="form-control" type="number" min="0" name="listing[price]" value="<%= listing.price %>" required>
          </div>

          <div class="mb-3 col-md-8">
            <label class="form-label">Location:</label>
            <input class="form-control" type="text" name="listing[location]" value="<%= listing.location %>" required>
          </div>

        <div class="mb-3 col-md-8">
          <label class="form-label">Category:</label>

          <select 
            class="form-select" 
            name="listing[category][]" 
            multiple 
            required
            style="height: 150px; padding: 10px; border-radius: 8px;"
          >
            <option value="Forest" <%= listing.category.includes('Forest') ? 'selected' : '' %>>🌲 Forest</option>
            
            <option value="City" <%= listing.category.includes('City') ? 'selected' : '' %>>🏙️ City</option>
            
            <option value="Camping" <%= listing.category.includes('Camping') ? 'selected' : '' %>>🏕️ Camping</option>
            
            <option value="Arctic" <%= listing.category.includes('Arctic') ? 'selected' : '' %>>❄️ Arctic</option>
            
            <option value="Resorts" <%= listing.category.includes('Resorts') ? 'selected' : '' %>>🏖️ Resorts</option>
            
            <option value="Villas" <%= listing.category.includes('Villas') ? 'selected' : '' %>>🏡 Villas</option>
          </select>

          <small style="color: gray;">
            Hold Ctrl (Windows) or Cmd (Mac) to select multiple
          </small>
        </div>
        </div>

        <!-- 🔥 CURRENT IMAGES -->
      <div class="mb-3">
  <label class="form-label">Current Images:</label>

  <div style="display:flex; gap:20px; flex-wrap:wrap;">

    <% listing.images.forEach((img) => { %>

      <div style="text-align:center;">

        <!-- IMAGE -->
        <img 
          src="<%= img.url %>" 
          style="
            width:180px;
            height:140px;
            object-fit:cover;
            border-radius:10px;
            box-shadow:0 2px 8px rgba(0,0,0,0.2);
          "
        >

        <!-- CHECKBOX -->
        <div style="margin-top:8px;">
          <input 
          
              type="checkbox" 
              name="deleteImages[]" 
              value="<%= img.url %>" 
            style="cursor:pointer;"
          >
          <span style="font-size:14px;">Delete</span>
        </div>

      </div>

    <% }) %>

  </div>
</div>

        <!-- 🔥 UPLOAD NEW IMAGES -->
        <div class="mb-3">
          <label class="form-label">Upload New Images:</label>
          <input 
            type="file" 
            name="listing[images][]" 
            multiple 
            class="form-control"
          >
        </div>

        <!-- SUBMIT -->
        <button type="submit" class="btn btn-dark add-btn">Update Listing</button>

      </form>
    </div>
  </div>
</body>